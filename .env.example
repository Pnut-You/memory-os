# 智谱 OpenAI-compatible 聊天模型；真实 Key 只填写在 .env。
LLM_API_KEY=
LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
LLM_MODEL=glm-4-flash

# 70B 偏好抽取器只允许后台 Worker 调用；主请求链路不会调用。
PREFERENCE_EXTRACTOR_ENABLED=true
PREFERENCE_EXTRACTOR_BASE_URL=https://open.bigmodel.cn/api/paas/v4
PREFERENCE_EXTRACTOR_API_KEY=
PREFERENCE_EXTRACTOR_MODEL=glm-4-flash
PREFERENCE_EXTRACT_BATCH_SIZE=8
PREFERENCE_EXTRACT_MIN_NEW_USER_MESSAGES=10
PREFERENCE_EXTRACT_MAX_ATTEMPTS=3

# 本地调试默认允许 Redis 不可用时内存降级；生产环境必须改为 false 并提供可用 Redis。
REDIS_URL=redis://localhost:6379/0
REDIS_TTL_SECONDS=86400
REDIS_ALLOW_MEMORY_FALLBACK=true
REDIS_PREFIX=memory-os

DEVICE_STATE_TTL_SECONDS=120
DEVICE_HEARTBEAT_SECONDS=300
TOOL_RUN_TTL_SECONDS=3600

MEMORY_DATA_DIR=data
MEMORY_SQLITE_PATH=data/events.db
MEMORY_LOCAL_LONG_TERM_PATH=data/long_term.jsonl
SUMMARY_EVERY_TURNS=10
SUMMARY_RETAIN_TURNS=5
