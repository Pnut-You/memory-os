# Qwen / DashScope OpenAI-compatible 聊天模型；真实 Key 只填写在 .env。
# 优先使用 DASHSCOPE_API_KEY；LLM_API_KEY 仅作为兼容旧配置的 fallback。
DASHSCOPE_API_KEY=
LLM_API_KEY=
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen3.7-plus

# 偏好记忆抽取器只允许后台 Worker 调用；主请求链路不会调用。
# small 为默认；hybrid 仅在 small 调用或严格校验失败时调用 large。
PREFERENCE_EXTRACTOR_ENABLED=true
PREFERENCE_EXTRACTOR_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# 为空时默认复用 DASHSCOPE_API_KEY。
PREFERENCE_EXTRACTOR_API_KEY=
# 兼容动作偏好抽取使用的旧配置。
PREFERENCE_EXTRACTOR_MODEL=qwen3.7-max
LONG_TERM_EXTRACTOR_MODE=small
LONG_TERM_SMALL_MODEL=codeqwen1.5-7b-chat
LONG_TERM_LARGE_MODEL=qwen3.7-max
PREFERENCE_EXTRACT_BATCH_SIZE=8
PREFERENCE_EXTRACT_MIN_NEW_USER_MESSAGES=10
PREFERENCE_EXTRACT_MAX_ATTEMPTS=3

# 本地调试默认允许 Redis 不可用时内存降级；生产环境必须改为 false 并提供可用 Redis。
REDIS_URL=redis://localhost:6379/0
REDIS_TTL_SECONDS=86400
REDIS_ALLOW_MEMORY_FALLBACK=true
REDIS_PREFIX=memory-os

DEVICE_STATE_TTL_SECONDS=120
DEVICE_HEARTBEAT_SECONDS=300
TOOL_RUN_TTL_SECONDS=3600

MEMORY_DATA_DIR=data
MEMORY_SQLITE_PATH=data/events.db
MEMORY_LOCAL_LONG_TERM_PATH=data/long_term.jsonl
SUMMARY_EVERY_TURNS=10
SUMMARY_RETAIN_TURNS=5
